PORT=5000

# Email service selection: gmail | sendgrid | mailgun | outlook
EMAIL_SERVICE=gmail

# Gmail app password setup: see GMAIL_SETUP_GUIDE.md
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# Recipient for contact messages (defaults to EMAIL_USER when missing)
CONTACT_EMAIL=recipient_email@example.com

# For SendGrid (if using EMAIL_SERVICE=sendgrid)
# SENDGRID_API_KEY=SG.xxxxxx

# For Mailgun (if using EMAIL_SERVICE=mailgun)
# MAILGUN_SMTP_USER=postmaster@sandboxxxxx.mailgun.org
# MAILGUN_SMTP_PASS=xxxxxxxx
PORT=5000
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_password
CONTACT_EMAIL=receiver_email@example.com
